[
  {
    "doctype": "Print Format",
    "name": "CB PM Task Checklist",
    "doc_type": "CB PM Task",
    "module": "Maintenance Ops",
    "standard": "Yes",
    "disabled": 0,
    "font": "Arial",
    "print_format_type": "Jinja",
    "html": "{% set status_color = {'Overdue': '#C8102E', 'Due': '#F4821F', 'Scheduled': '#1976d2', 'Completed': '#27AE60', 'Failed': '#C8102E'} %}\n{% set status_bg = {'Overdue': '#fde8ec', 'Due': '#fff3e0', 'Scheduled': '#e3f2fd', 'Completed': '#e8f5e9', 'Failed': '#fde8ec'} %}\n\n<style>\n  * { box-sizing: border-box; }\n  body { font-family: Arial, sans-serif; font-size: 13px; color: #1a1a1a; margin: 0; padding: 0; }\n  .cb-header { background: #C8102E; color: white; padding: 16px 24px; }\n  .cb-header-title { font-size: 20px; font-weight: bold; margin: 0; }\n  .cb-header-sub { font-size: 12px; opacity: 0.85; margin: 4px 0 0; }\n  .gold-bar { height: 5px; background: linear-gradient(90deg, #F7B731, #F4821F); }\n  .content { padding: 20px 24px; }\n  .detail-table { width: 100%; border-collapse: collapse; margin: 0 0 20px; }\n  .detail-table th { background: #f5f5f5; padding: 8px 12px; text-align: left; font-weight: 600; border: 1px solid #ddd; width: 160px; font-size: 12px; color: #555; }\n  .detail-table td { padding: 8px 12px; border: 1px solid #ddd; }\n  .status-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; border: 1px solid; }\n  .section-title { font-size: 14px; font-weight: 700; border-left: 4px solid #C8102E; padding-left: 10px; margin: 24px 0 12px; color: #1a1a1a; }\n  .checklist-item { display: flex; align-items: flex-start; margin: 10px 0; gap: 10px; }\n  .cb-checkbox { width: 16px; height: 16px; border: 2px solid #444; display: inline-block; flex-shrink: 0; margin-top: 1px; }\n  .notes-box { border: 1px solid #ccc; min-height: 72px; border-radius: 4px; padding: 8px; margin-bottom: 20px; }\n  .result-row { display: flex; gap: 32px; align-items: center; padding: 12px 16px; background: #f9f9f9; border: 1px solid #e5e5e5; border-radius: 5px; margin-bottom: 24px; }\n  .result-option { display: flex; align-items: center; gap: 8px; font-weight: 600; }\n  .result-checkbox { width: 18px; height: 18px; border: 2px solid #444; border-radius: 3px; display: inline-block; }\n  .sig-row { display: flex; justify-content: space-between; margin-top: 40px; gap: 20px; }\n  .sig-block { flex: 1; }\n  .sig-line { border-top: 1px solid #555; padding-top: 6px; font-size: 11px; color: #666; margin-top: 32px; }\n  .footer { margin-top: 32px; padding-top: 10px; border-top: 1px solid #eee; font-size: 10px; color: #999; text-align: center; }\n  @media print {\n    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n    .no-print { display: none !important; }\n  }\n</style>\n\n<!-- Header -->\n<div class=\"cb-header\">\n  <p class=\"cb-header-title\">California Burrito — PM Checklist</p>\n  <p class=\"cb-header-sub\">Preventive Maintenance Task Sheet &nbsp;|&nbsp; {{ doc.name }}</p>\n</div>\n<div class=\"gold-bar\"></div>\n\n<div class=\"content\">\n\n  <!-- Task Details -->\n  <table class=\"detail-table\">\n    <tr>\n      <th>Task ID</th>\n      <td><strong>{{ doc.name }}</strong></td>\n      <th style=\"width:120px;\">Status</th>\n      <td>\n        <span class=\"status-badge\" style=\"color: {{ status_color.get(doc.status, '#666') }}; background: {{ status_bg.get(doc.status, '#f5f5f5') }}; border-color: {{ status_color.get(doc.status, '#ccc') }};\">\n          {{ doc.status }}\n        </span>\n      </td>\n    </tr>\n    <tr>\n      <th>Task</th>\n      <td colspan=\"3\"><strong>{{ doc.task }}</strong></td>\n    </tr>\n    <tr>\n      <th>Asset Type</th>\n      <td>{{ doc.asset_type or '—' }}</td>\n      <th>Outlet</th>\n      <td>{{ doc.outlet or '—' }}</td>\n    </tr>\n    <tr>\n      <th>Due Date</th>\n      <td style=\"color: {{ '#C8102E' if doc.status == 'Overdue' else 'inherit' }}; font-weight: {{ 'bold' if doc.status == 'Overdue' else 'normal' }};\">{{ doc.due_date }}</td>\n      <th>Frequency</th>\n      <td>{{ doc.frequency or 'One-time' }}</td>\n    </tr>\n    {% if doc.notes %}\n    <tr>\n      <th>Instructions</th>\n      <td colspan=\"3\" style=\"white-space: pre-wrap;\">{{ doc.notes }}</td>\n    </tr>\n    {% endif %}\n  </table>\n\n  <!-- Inspection Checklist -->\n  <div class=\"section-title\">Inspection Checklist</div>\n\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>Equipment visually inspected — no visible damage, leaks, unusual noise, or corrosion</span>\n  </div>\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>Task performed as per SOP: <em><strong>{{ doc.task }}</strong></em></span>\n  </div>\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>Filters, seals, or consumables checked — replaced if worn or required</span>\n  </div>\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>Equipment tested post-maintenance — operating within normal parameters</span>\n  </div>\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>Work area cleaned and restored; no tools or materials left behind</span>\n  </div>\n  <div class=\"checklist-item\">\n    <span class=\"cb-checkbox\"></span>\n    <span>No further issues identified &nbsp;/&nbsp; Issues found — ticket raised &nbsp; Ticket No: ___________________________</span>\n  </div>\n\n  <!-- Observations -->\n  <div class=\"section-title\">Observations / Spare Parts Used</div>\n  <div class=\"notes-box\"></div>\n\n  <!-- Result -->\n  <div class=\"section-title\">Result</div>\n  <div class=\"result-row\">\n    <div class=\"result-option\">\n      <span class=\"result-checkbox\" style=\"border-color: #27AE60;\"></span>\n      <span style=\"color: #27AE60;\">Passed — task complete, no issues</span>\n    </div>\n    <div class=\"result-option\">\n      <span class=\"result-checkbox\" style=\"border-color: #C8102E;\"></span>\n      <span style=\"color: #C8102E;\">Failed — follow-up ticket raised (see above)</span>\n    </div>\n  </div>\n\n  <!-- Signatures -->\n  <div class=\"sig-row\">\n    <div class=\"sig-block\">\n      <div class=\"sig-line\">Technician Name</div>\n    </div>\n    <div class=\"sig-block\">\n      <div class=\"sig-line\">Technician Signature</div>\n    </div>\n    <div class=\"sig-block\">\n      <div class=\"sig-line\">Date Completed</div>\n    </div>\n    <div class=\"sig-block\">\n      <div class=\"sig-line\">Supervisor Sign-off</div>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div class=\"footer\">\n    California Burrito Maintenance Ops &nbsp;&bull;&nbsp; {{ doc.name }} &nbsp;&bull;&nbsp; Outlet: {{ doc.outlet or '—' }} &nbsp;&bull;&nbsp; Printed: {{ frappe.utils.nowdate() }}\n  </div>\n\n</div>"
  }
]
